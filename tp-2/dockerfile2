FROM node:24 AS builder
WORKDIR /app
COPY . .
RUN npm install
RUN npm run build


FROM node:24
WORKDIR /app
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/dist ./dist

RUN useradd -m nestdevops
RUN chown -R nestdevops:nestdevops /app
USER nestdevops

CMD ["node", "dist/main.js"]
